#!/bin/bash
pkill -f "foot.*org.screensaver" 2>/dev/null
dms ipc call lock lock

# After lock: turn off monitors in 30s, suspend in 5min
# Only if still locked
(
  sleep 30
  dms ipc call lock isLocked 2>/dev/null | grep -q "true" || exit 0
  niri msg action power-off-monitors

  sleep 270  # 4.5min more = 5min total
  dms ipc call lock isLocked 2>/dev/null | grep -q "true" || exit 0
  systemctl suspend
) &
