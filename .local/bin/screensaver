#!/bin/bash
# set -x

LOGO="${XDG_CONFIG_HOME:-$HOME/.config}/screensaver/logo.txt"
FRAME_RATE=$(niri msg outputs | grep "Current mode" | awk '{print int($5)}')
FRAME_RATE=${FRAME_RATE:-60}
EXCLUDED_EFFECTS="dev_worm"

exit_screensaver() {
    pkill -x tte 2>/dev/null
    exit 0
}

trap exit_screensaver SIGINT SIGTERM

set_terminal() {
    printf '\033]11;rgb:00/00/00\007'
    printf '\033[?25l'
}

run_effect() {
    tte -i "$LOGO" \
        --frame-rate "$FRAME_RATE" \
        --canvas-width 0 \
        --canvas-height 0 \
        --reuse-canvas \
        --anchor-canvas c \
        --anchor-text c \
        --random-effect \
        --exclude-effects "$EXCLUDED_EFFECTS" \
        --no-eol \
        --no-restore-cursor
}

wait_for_input() {
    while pgrep -x tte >/dev/null; do
        if read -n1 -t 1; then
            exit_screensaver
        fi
    done
}

launch() {
    exec foot --app-id=org.screensaver --fullscreen -- "$0" --run
}

main() {
    set_terminal
    while true; do
        run_effect &
        wait_for_input
    done
}

case "${1:-}" in
    --run) main ;;
    *)     launch ;;
esac
