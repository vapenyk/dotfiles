#!/bin/bash
LOGO="${XDG_CONFIG_HOME:-$HOME/.config}/screensaver/logo.txt"
EXCLUDED_EFFECTS="dev_worm"

# --- Determine refresh rate ---
# Try wlr-randr (niri/sway/wlroots), then kscreen-doctor (KDE)
FRAME_RATE=$(wlr-randr 2>/dev/null | grep -oP '\d+(?=\.\d+ Hz \(.*current.*\))' | head -1)
if [ -z "$FRAME_RATE" ]; then
    FRAME_RATE=$(kscreen-doctor -o 2>/dev/null | grep -oP '(?<=@)\d+(?=[\.\d]*\*)' | head -1)
fi
FRAME_RATE=${FRAME_RATE:-60}

# --- Focus check ---
# niri: use niri msg
# KDE/KWin: use qdbus
screensaver_in_focus() {
    if pgrep -x niri >/dev/null 2>&1; then
        niri msg focused-window 2>/dev/null | grep -q 'org.screensaver'
    else
        local active_id
        active_id=$(qdbus org.kde.KWin /KWin activeWindow 2>/dev/null)
        [ -z "$active_id" ] && return 0  # qdbus unavailable — assume in focus
        qdbus org.kde.KWin "/org/kde/KWin/Window/$active_id" resourceClass 2>/dev/null \
            | grep -qi "screensaver"
    fi
}

exit_screensaver() {
    printf '\033[?25h'  # restore cursor
    pkill -x tte 2>/dev/null
    exit 0
}

trap exit_screensaver SIGINT SIGTERM SIGHUP SIGQUIT

set_terminal() {
    printf '\033]11;rgb:00/00/00\007'  # black background
    printf '\033[?25l'                  # hide cursor
}

run_effect() {
    tte -i "$LOGO" \
        --frame-rate "$FRAME_RATE" \
        --canvas-width 0 --canvas-height 0 \
        --reuse-canvas --anchor-canvas c --anchor-text c \
        --random-effect --exclude-effects "$EXCLUDED_EFFECTS" \
        --no-eol --no-restore-cursor &
}

wait_for_input() {
    while pgrep -x tte >/dev/null; do
        if read -n1 -t 1 || ! screensaver_in_focus; then
            exit_screensaver
        fi
    done
}

launch() {
    exec foot --app-id=org.screensaver --fullscreen -- "$0" --run
}

main() {
    set_terminal
    while true; do
        run_effect
        wait_for_input
    done
}

case "${1:-}" in
    --run) main ;;
    *)     launch ;;
esac
