# ── Example hook scripts ───────────────────────────────────────────────────────

_EXAMPLE_BEFORE_SYNC = """\
#!/usr/bin/env bash
# ~/.config/pkg/scripts/before-sync.sh
# Runs before EVERY `pkg sync`. Edit freely — runs each time, not just once.
#
# Available env vars:
#   PKG_EVENT       = "before-sync"
#   PKG_CONFIG_DIR  = path to ~/.config/pkg
#   PKG_DATA_DIR    = path to ~/.local/share/pkg
set -euo pipefail

echo "[pkg hook] before-sync — $(date '+%Y-%m-%d %H:%M')"

# Uncomment to pull dotfiles before installing new packages:
# cd ~/dotfiles && git pull --ff-only

# Uncomment to check for pending system updates first:
# checkupdates || true
"""

_EXAMPLE_AFTER_SYNC = """\
#!/usr/bin/env bash
# ~/.config/pkg/scripts/after-sync.sh
# Runs after EVERY `pkg sync`. Edit freely — runs each time, not just once.
#
# Available env vars:
#   PKG_EVENT       = "after-sync"
#   PKG_CONFIG_DIR  = path to ~/.config/pkg
#   PKG_DATA_DIR    = path to ~/.local/share/pkg
set -euo pipefail

echo "[pkg hook] after-sync — $(date '+%Y-%m-%d %H:%M')"

# Uncomment to apply dotfiles via stow after all packages are in place:
# cd ~/dotfiles && stow --restow --ignore='.git' .

# Uncomment for a desktop notification when sync finishes:
# notify-send "pkg sync" "All packages installed" --icon=package-x-generic
"""

_EXAMPLE_BOOTSTRAP_PARU = """\
#!/usr/bin/env bash
# ~/.config/pkg/scripts/bootstrap-paru.sh
# Called automatically when paru is not in official repos.
# Builds paru from AUR using only base-devel (always available on Arch).
set -euo pipefail

echo "[pkg bootstrap] Building paru from AUR..."

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

git clone --depth=1 https://aur.archlinux.org/paru.git "$tmpdir"
cd "$tmpdir"
makepkg -si --noconfirm

echo "[pkg bootstrap] paru installed successfully"
"""


# =============================================================================
# SECTION 10 — CLI & ARGUMENT PARSING
# =============================================================================


def _add_group_args(parser: argparse.ArgumentParser):
    """Add group filtering arguments to a subcommand (sync, diff, prune)."""
    _ = parser.add_argument(
        "groups",
        nargs="*",
        metavar="GROUP",
        help=(
            "Process only these groups (e.g. 'base wayland'). "
            "Omit to process all groups. See 'pkg groups' for available names."
        ),
    )
    _ = parser.add_argument(
        "--exclude",
        "-x",
        nargs="+",
        metavar="GROUP",
        help="Exclude specific groups (combinable with positional group filter)",
    )


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="pkg",
        description="Declarative package manager for Arch Linux",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Quick start:
              pkg init                    create default config files
              pkg sync                    install everything in config
              pkg groups                  list available groups

            Group filtering (works in sync, diff, prune):
              pkg sync base wayland       install only base + wayland groups
              pkg sync --exclude apps     install all except apps
              pkg diff flatpak            preview flatpak group only

            Hook scripts (in ~/.config/pkg/scripts/):
              before-sync.sh              runs before every sync
              after-sync.sh               runs after every sync
              before-{backend}.sh         runs before each backend batch
              after-{backend}.sh          runs after each backend batch

            Config:    ~/.config/pkg/
            Database:  ~/.local/share/pkg/installed.db

            Override paths with env vars:
              PKG_CONFIG_DIR, PKG_DATA_DIR
        """),
    )
    _ = parser.add_argument("--version", action="version", version=f"pkg {VERSION}")

    sub = parser.add_subparsers(dest="command", metavar="COMMAND")

    # init
    p = sub.add_parser("init", help="Create default config files + example scripts")
    _ = p.add_argument("--force", action="store_true", help="Overwrite existing files")
    p.set_defaults(func=cmd_init)

    # sync
    p = sub.add_parser(
        "sync",
        help="Install packages from config",
        description=textwrap.dedent("""\
            Install everything defined in packages/*.toml.
            Groups are processed in priority order ([group] priority = N).
            Lifecycle hook scripts in scripts/ are executed automatically.
        """),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    _add_group_args(p)
    _ = p.add_argument(
        "--skip-errors",
        action="store_true",
        help="Continue to next package if one fails to install",
    )
    _ = p.add_argument(
        "--strict-hooks",
        action="store_true",
        help="Abort if any hook script exits non-zero (default: warn and continue)",
    )
    p.set_defaults(func=cmd_sync)

    # diff
    p = sub.add_parser(
        "diff",
        help="Preview changes without touching anything (read-only)",
        description="Compare config files against the database. Makes no changes.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    _add_group_args(p)
    p.set_defaults(func=cmd_diff)

    # prune
    p = sub.add_parser(
        "prune",
        help="Remove packages no longer in config (interactive)",
        description=textwrap.dedent("""\
            Find packages installed by pkg that have been removed from config.
            Asks interactively before removing each one.
            Packages installed manually (outside pkg) are never touched.
        """),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    _add_group_args(p)
    p.set_defaults(func=cmd_prune)

    # groups
    p = sub.add_parser(
        "groups",
        help="List available package groups with priority and package counts",
    )
    p.set_defaults(func=cmd_groups)

    # status
    p = sub.add_parser(
        "status",
        help="Show backend availability, package progress, and hook scripts",
    )
    p.set_defaults(func=cmd_status)

    # list
    p = sub.add_parser(
        "list",
        help="List all packages tracked in the database",
    )
    p.set_defaults(func=cmd_list)

    return parser


# =============================================================================
# SECTION 11 — ENTRY POINT
# =============================================================================


def main():
    db_init()  # ensure schema exists before any command touches the DB

    parser = _build_parser()
    args = parser.parse_args()

    if not hasattr(args, "func"):
        parser.print_help()
        sys.exit(0)

    try:
        args.func(args)
    except KeyboardInterrupt:
        print()
        print_warn("Interrupted.")
        sys.exit(130)


if __name__ == "__main__":
    main()
